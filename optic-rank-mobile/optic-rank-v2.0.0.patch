+    <View>
+      <View style={styles.usageLabelRow}>
+        <Text style={[styles.usageLabel, { color: colors.ink }]}>{label}</Text>
+        <Text style={[styles.usageValue, { color: colors.ink }]}>
+          {used} / {max}
+        </Text>
+      </View>
+      <ProgressBar value={pct} color={barColor} />
+    </View>
