+import { useActiveProject } from "../hooks/useProjects";
+
+import type { Keyword } from "../types";
+import type { KeywordVisibility } from "../hooks/useVisibility";
+
+// ---------------------------------------------------------------------------
+// Constants
+// ---------------------------------------------------------------------------
+
+/** Map SERP feature slugs to readable labels and badge variants */
+const SERP_FEATURE_META: Record<
+  string,
+  { label: string; variant: "red" | "green" | "gold" | "blue" | "dark" | "outline" }
+> = {
+  featured_snippet: { label: "Featured Snippet", variant: "red" },
+  knowledge_panel: { label: "Knowledge Panel", variant: "blue" },
+  local_pack: { label: "Local Pack", variant: "green" },
+  image_pack: { label: "Image Pack", variant: "gold" },
+  video: { label: "Video", variant: "dark" },
+  top_stories: { label: "Top Stories", variant: "red" },
+  people_also_ask: { label: "People Also Ask", variant: "outline" },
+  sitelinks: { label: "Sitelinks", variant: "green" },
+  shopping: { label: "Shopping", variant: "gold" },
+  reviews: { label: "Reviews", variant: "blue" },
+  faq: { label: "FAQ", variant: "outline" },
+  twitter: { label: "Twitter", variant: "blue" },
+};
+
+function getSerpFeatureMeta(feature: string) {
+  return (
+    SERP_FEATURE_META[feature] ?? {
+      label: feature.replace(/_/g, " ").replace(/\b\w/g, (c) => c.toUpperCase()),
+      variant: "outline" as const,
+    }
+  );
+}
+
+// ---------------------------------------------------------------------------
+// Component
+// ---------------------------------------------------------------------------
+
+export default function SearchAIScreen() {
+  const { colors } = useTheme();
+
+  // --- Data hooks ---
+  const { data: project, isLoading: projectLoading } = useActiveProject();
+  const projectId = project?.id;
+
+  const {
+    data: keywordsResult,
+    isLoading: keywordsLoading,
+    refetch: refetchKeywords,
+    isRefetching: isRefetchingKeywords,
+  } = useKeywords(projectId, { limit: 100 });
+
+  const {
+    data: visibilityByKeyword,
+    refetch: refetchVisibility,
+    isRefetching: isRefetchingVisibility,
+  } = useVisibilityByKeyword(projectId);
+
+  const keywords = keywordsResult?.data ?? [];
+  const visibilityData = visibilityByKeyword ?? [];
+
+  // --- Derived data ---
+
+  // Keywords with SERP features
+  const keywordsWithSerpFeatures = useMemo(() => {
+    return keywords.filter(
+      (kw: Keyword) => kw.serp_features && kw.serp_features.length > 0
+    );
+  }, [keywords]);
+
+  // Build visibility lookup by keyword ID
+  const visibilityMap = useMemo(() => {
+    const map = new Map<string, KeywordVisibility>();
+    for (const v of visibilityData) {
+      map.set(v.keywordId, v);
+    }
+    return map;
+  }, [visibilityData]);
+
+  // Keywords present in both traditional search (have a position) and AI search (have visibility)
+  const crossoverKeywords = useMemo(() => {
+    return keywords
+      .filter((kw: Keyword) => {
+        const hasPosition = kw.current_position !== null;
+        const vis = visibilityMap.get(kw.id);
+        const hasVisibility =
+          vis !== undefined && vis.visibilityScore !== null && vis.visibilityScore > 0;
+        return hasPosition && hasVisibility;
+      })
+      .map((kw: Keyword) => {
+        const vis = visibilityMap.get(kw.id)!;
+        return {
+          id: kw.id,
+          keyword: kw.keyword,
+          position: kw.current_position!,
+          aiScore: vis.visibilityScore ?? 0,
+          aiCount: vis.visibilityCount,
+        };
+      });
+  }, [keywords, visibilityMap]);
+
+  // --- Refresh ---
+  const handleRefresh = useCallback(() => {
+    refetchKeywords();
+    refetchVisibility();
+  }, [refetchKeywords, refetchVisibility]);
+
+  // --- Loading ---
+  if (projectLoading || (keywordsLoading && !keywordsResult)) {
+    return <LoadingScreen />;
+  }
+
+  return (
+    <SafeAreaView
+      style={[styles.safeArea, { backgroundColor: colors.background }]}
+      edges={["top"]}
+    >
+      <ScrollView
+        style={styles.scrollView}
+        refreshControl={
+          <RefreshControl
+            refreshing={isRefetchingKeywords || isRefetchingVisibility}
+            onRefresh={handleRefresh}
+            tintColor={colors.red}
+          />
+        }
+        contentContainerStyle={styles.scrollContent}
+      >
+        {/* Header */}
+        <View style={styles.header}>
+          <Text style={[styles.headerTitle, { color: colors.ink }]}>
+            Search AI Intelligence
+          </Text>
+          <Text style={[styles.headerSubtitle, { color: colors.inkMuted }]}>
+            How search engines understand your content
+          </Text>
+        </View>
+
+        <Divider />
+
+        {/* ---------------------------------------------------------------- */}
+        {/* SERP Features Section                                            */}
+        {/* ---------------------------------------------------------------- */}
+        <View style={styles.section}>
+          <SectionLabel text="SERP Features" />
+
+          {keywordsWithSerpFeatures.length === 0 ? (
+            <EmptyState
+              title="No SERP Features"
+              message="None of your tracked keywords currently trigger SERP features. Data will appear once search engines return rich results for your keywords."
+            />
+          ) : (
+            keywordsWithSerpFeatures.map((kw: Keyword) => (
+              <Card key={kw.id} variant="sm">
+                <View style={styles.serpRow}>
+                  <View style={styles.serpInfo}>
+                    <Text
+                      style={[styles.serpKeyword, { color: colors.ink }]}
+                      numberOfLines={1}
+                    >
+                      {kw.keyword}
+                    </Text>
+                    <Text style={[styles.serpPosition, { color: colors.inkSecondary }]}>
+                      Position:{" "}
+                      <Text style={styles.monoText}>
+                        {kw.current_position != null ? `#${kw.current_position}` : "--"}
+                      </Text>
+                    </Text>
+                  </View>
+                </View>
+
+                {/* SERP feature badges */}
+                <View style={styles.badgeRow}>
+                  {(kw.serp_features ?? []).map((feature, index) => {
+                    const meta = getSerpFeatureMeta(feature);
+                    return (
+                      <Badge
+                        key={`${kw.id}-${feature}-${index}`}
+                        label={meta.label}
+                        variant={meta.variant}
+                      />
+                    );
+                  })}
+                </View>
+              </Card>
+            ))
+          )}
+        </View>
+
+        <Divider />
+
+        {/* ---------------------------------------------------------------- */}
+        {/* AI Search Crossover Section                                      */}
+        {/* ---------------------------------------------------------------- */}
+        <View style={styles.section}>
+          <SectionLabel text="AI Search Crossover" />
+          <Text style={[styles.sectionDescription, { color: colors.inkMuted }]}>
+            Keywords visible in both traditional search and AI search results
+          </Text>
+
+          {crossoverKeywords.length === 0 ? (
+            <EmptyState
+              title="No Crossover Data"
+              message="Keywords appearing in both traditional and AI search will be shown here once AI visibility checks have been completed."
+            />
+          ) : (
+            <>
+              {/* Column headers */}
+              <View style={styles.crossoverHeader}>
+                <Text
+                  style={[styles.crossoverHeaderLabel, { color: colors.inkMuted }]}
+                  numberOfLines={1}
+                >
+                  Keyword
+                </Text>
+                <Text style={[styles.crossoverHeaderValue, { color: colors.inkMuted }]}>
+                  SERP
+                </Text>
+                <Text style={[styles.crossoverHeaderValue, { color: colors.inkMuted }]}>
+                  AI Score
+                </Text>
+              </View>
+
+              <Card>
+                {crossoverKeywords.map((item, index) => {
+                  const positionColor =
+                    item.position <= 3
+                      ? colors.green
+                      : item.position <= 10
+                      ? colors.gold
+                      : colors.ink;
+                  const aiColor =
+                    item.aiScore >= 70
+                      ? colors.green
+                      : item.aiScore >= 40
+                      ? colors.gold
+                      : colors.red;
+
+                  return (
+                    <View key={item.id}>
+                      {index > 0 && <Divider />}
+                      <View style={styles.crossoverRow}>
+                        <Text
+                          style={[styles.crossoverKeyword, { color: colors.ink }]}
+                          numberOfLines={1}
+                        >
+                          {item.keyword}
+                        </Text>
+                        <Text style={[styles.crossoverValue, { color: positionColor }]}>
+                          #{item.position}
+                        </Text>
+                        <Text style={[styles.crossoverValue, { color: aiColor }]}>
+                          {item.aiScore}%
+                        </Text>
+                      </View>
+                    </View>
+                  );
+                })}
+              </Card>
+
+              {/* Summary */}
+              <Card variant="sm" style={styles.summaryCard}>
+                <Text style={[styles.summaryText, { color: colors.inkSecondary }]}>
+                  <Text style={styles.summaryBold}>
+                    {crossoverKeywords.length}
+                  </Text>{" "}
+                  keywords appear in both traditional and AI search results
+                </Text>
+              </Card>
+            </>
+          )}
+        </View>
+
+        <View style={styles.bottomSpacer} />
+      </ScrollView>
+    </SafeAreaView>
+  );
+}
+
+// ---------------------------------------------------------------------------
+// Styles
+// ---------------------------------------------------------------------------
+
+const styles = StyleSheet.create({
+  safeArea: {
+    flex: 1,
+  },
+  scrollView: {
+    flex: 1,
+  },
+  scrollContent: {
+    paddingBottom: 100,
+  },
+  header: {
+    paddingHorizontal: spacing.screenPadding,
+    paddingTop: spacing.lg,
+  },
+  headerTitle: {
+    fontFamily: fonts.serifBlack,
+    fontSize: fontSize.xl,
+  },
+  headerSubtitle: {
+    fontFamily: fonts.sans,
+    fontSize: 11,
+    marginTop: 4,
+  },
+  section: {
+    paddingHorizontal: spacing.screenPadding,
+  },
+  sectionDescription: {
+    fontFamily: fonts.sans,
+    fontSize: 11,
+    marginBottom: 12,
+    lineHeight: 16,
+  },
+
+  // SERP features
+  serpRow: {
+    flexDirection: "row",
+    alignItems: "center",
+    gap: 12,
+  },
+  serpInfo: {
+    flex: 1,
+  },
+  serpKeyword: {
+    fontFamily: fonts.sansBold,
+    fontSize: 12,
+  },
+  serpPosition: {
