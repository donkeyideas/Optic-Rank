+import React from "react";
+import { Platform } from "react-native";
+import { createNativeStackNavigator } from "@react-navigation/native-stack";
+import { createBottomTabNavigator } from "@react-navigation/bottom-tabs";
+import { Feather } from "@expo/vector-icons";
+import { useTheme } from "../theme/ThemeContext";
+import { fonts, fontSize } from "../theme/typography";
+
+// ── Tab screens ─────────────────────────────────────────────────────────────
+import DashboardScreen from "../screens/DashboardScreen";
+import KeywordsScreen from "../screens/KeywordsScreen";
+import AIInsightsScreen from "../screens/AIInsightsScreen";
+import ProfileScreen from "../screens/ProfileScreen";
+import MoreScreen from "../screens/MoreScreen";
+
+// ── Stack screens ───────────────────────────────────────────────────────────
+import CompetitorsScreen from "../screens/CompetitorsScreen";
+import SiteAuditScreen from "../screens/SiteAuditScreen";
+import SettingsScreen from "../screens/SettingsScreen";
+import BillingScreen from "../screens/BillingScreen";
+import BacklinksScreen from "../screens/BacklinksScreen";
+import ContentScreen from "../screens/ContentScreen";
+import AIVisibilityScreen from "../screens/AIVisibilityScreen";
+import PredictionsScreen from "../screens/PredictionsScreen";
+import EntitiesScreen from "../screens/EntitiesScreen";
+import AIBriefsScreen from "../screens/AIBriefsScreen";
+import OptimizationScreen from "../screens/OptimizationScreen";
+import AppStoreScreen from "../screens/AppStoreScreen";
+import SearchAIScreen from "../screens/SearchAIScreen";
+import SocialIntelligenceScreen from "../screens/SocialIntelligenceScreen";
+import ReportsScreen from "../screens/ReportsScreen";
+import AdvancedAIScreen from "../screens/AdvancedAIScreen";
+import KeywordClustersScreen from "../screens/KeywordClustersScreen";
+
+// ── Param lists ─────────────────────────────────────────────────────────────
+
+export type TabParamList = {
+  Home: undefined;
+  Keywords: undefined;
+  AI: undefined;
+  More: undefined;
+  Profile: undefined;
+};
+
+export type AppStackParamList = {
+  Tabs: undefined;
+  // SEO tools
+  Compete: undefined;
+  Backlinks: undefined;
+  SiteAudit: undefined;
+  Content: undefined;
+  Optimization: undefined;
+  KeywordClusters: undefined;
+  // AI features
+  AIVisibility: undefined;
+  Predictions: undefined;
+  AIBriefs: undefined;
+  AdvancedAI: undefined;
+  SearchAI: undefined;
+  Entities: undefined;
+  // Channels
+  AppStore: undefined;
+  SocialIntelligence: undefined;
+  // Account
+  Reports: undefined;
+  Settings: undefined;
+  Billing: undefined;
+};
+
+// ── Tab navigator ───────────────────────────────────────────────────────────
+
+const Tab = createBottomTabNavigator<TabParamList>();
+
+const TAB_ICONS: Record<keyof TabParamList, keyof typeof Feather.glyphMap> = {
+  Home: "home",
+  Keywords: "search",
+  AI: "zap",
+  More: "grid",
+  Profile: "user",
+};
+
+function TabNavigator() {
+  const { colors } = useTheme();
+
+  return (
+    <Tab.Navigator
+      screenOptions={({ route }) => ({
+        headerShown: false,
+        tabBarIcon: ({ color }) => (
+          <Feather
+            name={TAB_ICONS[route.name as keyof TabParamList]}
+            size={22}
+            color={color}
+          />
+        ),
+        tabBarActiveTintColor: "#c0392b",
+        tabBarInactiveTintColor: "#999999",
+        tabBarLabelStyle: {
+          fontFamily: Platform.select({
+            ios: "IBMPlexSans-Medium",
+            android: "IBMPlexSans-Medium",
+            default: undefined,
+          }),
+          fontSize: 9,
+        },
+        tabBarStyle: {
+          backgroundColor: colors.tabBar,
+          borderTopWidth: 1,
+          borderTopColor: colors.tabBarBorder,
+          borderRadius: 0,
+          paddingTop: 4,
+          paddingBottom: 4,
+          height: 56,
+        },
+      })}
+    >
+      <Tab.Screen
+        name="Home"
+        component={DashboardScreen}
+        options={{ tabBarLabel: "Home" }}
+      />
+      <Tab.Screen
+        name="Keywords"
+        component={KeywordsScreen}
+        options={{ tabBarLabel: "Keywords" }}
+      />
+      <Tab.Screen
+        name="AI"
+        component={AIInsightsScreen}
+        options={{ tabBarLabel: "AI" }}
+      />
+      <Tab.Screen
+        name="More"
+        component={MoreScreen}
+        options={{ tabBarLabel: "More" }}
+      />
+      <Tab.Screen
+        name="Profile"
+        component={ProfileScreen}
+        options={{ tabBarLabel: "Profile" }}
+      />
+    </Tab.Navigator>
+  );
+}
+
+// ── Root stack wrapping tabs + all sub-screens ──────────────────────────────
+
+const Stack = createNativeStackNavigator<AppStackParamList>();
+
+export default function AppStack() {
+  const { colors } = useTheme();
+
+  const screenOptions = {
+    headerStyle: { backgroundColor: colors.surface },
+    headerTintColor: colors.ink,
+    headerTitleStyle: {
+      fontFamily: Platform.select({
+        ios: "IBMPlexSans-SemiBold",
+        android: "IBMPlexSans-SemiBold",
+        default: undefined,
+      }),
+      fontSize: 16,
+    },
+    headerBackButtonDisplayMode: "minimal" as const,
+  };
+
+  return (
+    <Stack.Navigator screenOptions={screenOptions}>
+      <Stack.Screen
+        name="Tabs"
+        component={TabNavigator}
+        options={{ headerShown: false }}
+      />
+
+      {/* SEO Tools */}
+      <Stack.Screen name="Compete" component={CompetitorsScreen} options={{ title: "Competitors" }} />
+      <Stack.Screen name="Backlinks" component={BacklinksScreen} options={{ title: "Backlinks" }} />
+      <Stack.Screen name="SiteAudit" component={SiteAuditScreen} options={{ title: "Site Audit" }} />
+      <Stack.Screen name="Content" component={ContentScreen} options={{ title: "Content" }} />
+      <Stack.Screen name="Optimization" component={OptimizationScreen} options={{ title: "Optimization" }} />
+      <Stack.Screen name="KeywordClusters" component={KeywordClustersScreen} options={{ title: "Keyword Clusters" }} />
+
+      {/* AI Features */}
+      <Stack.Screen name="AIVisibility" component={AIVisibilityScreen} options={{ title: "AI Visibility" }} />
+      <Stack.Screen name="Predictions" component={PredictionsScreen} options={{ title: "Predictions" }} />
+      <Stack.Screen name="AIBriefs" component={AIBriefsScreen} options={{ title: "AI Briefs" }} />
+      <Stack.Screen name="AdvancedAI" component={AdvancedAIScreen} options={{ title: "Advanced AI" }} />
+      <Stack.Screen name="SearchAI" component={SearchAIScreen} options={{ title: "Search AI" }} />
+      <Stack.Screen name="Entities" component={EntitiesScreen} options={{ title: "Entities" }} />
+
+      {/* Channels */}
+      <Stack.Screen name="AppStore" component={AppStoreScreen} options={{ title: "App Store" }} />
+      <Stack.Screen name="SocialIntelligence" component={SocialIntelligenceScreen} options={{ title: "Social Intelligence" }} />
+
+      {/* Account */}
+      <Stack.Screen name="Reports" component={ReportsScreen} options={{ title: "Reports" }} />
+      <Stack.Screen name="Settings" component={SettingsScreen} options={{ title: "Settings" }} />
+      <Stack.Screen name="Billing" component={BillingScreen} options={{ title: "Billing" }} />
+    </Stack.Navigator>
+  );
+}
