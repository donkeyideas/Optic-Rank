+import { spacing } from "../theme/spacing";
+
+import Card from "../components/ui/Card";
+import Badge from "../components/ui/Badge";
+import SectionLabel from "../components/ui/SectionLabel";
+import Divider from "../components/ui/Divider";
+import Toggle from "../components/ui/Toggle";
+import LoadingScreen from "../components/ui/LoadingScreen";
+
+import { useActiveProject } from "../hooks/useProjects";
+
+// ---------------------------------------------------------------------------
+// Component
+// ---------------------------------------------------------------------------
+
+export default function SettingsScreen() {
+  const { colors, isDark, toggleTheme } = useTheme();
+  const { data: project, isLoading: projectLoading } = useActiveProject();
+
+  // Notification toggles (local state, not persisted)
+  const [pushNotifications, setPushNotifications] = useState(true);
+  const [emailReports, setEmailReports] = useState(true);
+  const [rankDropAlerts, setRankDropAlerts] = useState(true);
+  const [competitorAlerts, setCompetitorAlerts] = useState(false);
+
+  // Appearance toggles
+  const [compactView, setCompactView] = useState(false);
+
+  // Integration statuses from project data
+  const integrations = [
+    {
+      letter: "G",
+      color: "#4285F4",
+      name: "Google Search Console",
+      description: "Search performance data",
+      connected: project?.search_engines?.includes("google") ?? false,
+    },
+    {
+      letter: "A",
+      color: "#E37400",
+      name: "Google Analytics 4",
+      description: "Traffic and conversion data",
+      connected: false, // populated when integration is set up
+    },
+    {
+      letter: "S",
+      color: "#4A154B",
