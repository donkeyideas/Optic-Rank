+                      </Text>
+                      <Text
+                        style={[
+                          styles.entityRelevanceValue,
+                          { color: colors.ink },
+                        ]}
+                      >
+                        {entity.relevance_score ?? 0}%
+                      </Text>
+                    </View>
+                    <ProgressBar
+                      value={entity.relevance_score ?? 0}
+                      color={
+                        (entity.relevance_score ?? 0) >= 70
+                          ? colors.green
+                          : (entity.relevance_score ?? 0) >= 40
+                          ? colors.gold
