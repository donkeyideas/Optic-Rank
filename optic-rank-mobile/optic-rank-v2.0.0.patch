+                  </Text>
+                  <Badge
+                    label={entity.entity_type}
+                    variant={entityTypeBadgeVariant(entity.entity_type)}
+                  />
+                </View>
+
+                {/* Description */}
+                {entity.description && (
+                  <Text
+                    style={[
+                      styles.entityDescription,
+                      { color: colors.inkSecondary },
+                    ]}
+                    numberOfLines={2}
+                  >
+                    {entity.description}
+                  </Text>
+                )}
+
+                {/* Relevance bar + source */}
+                <View style={styles.entityMetaRow}>
